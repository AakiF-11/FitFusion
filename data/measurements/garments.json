{
  "_meta": {
    "description": "Real garment measurements per size variant for all test garments in the FitFusion size-aware system",
    "unit": "cm",
    "measurement_guide": {
      "chest_cm": "Full garment chest circumference (flat measurement × 2). Represents how wide the garment is across the chest.",
      "waist_cm": "Full garment waist circumference (flat × 2).",
      "hem_cm": "Full garment hem/bottom circumference (flat × 2).",
      "shoulder_cm": "Shoulder seam to shoulder seam across the back.",
      "sleeve_cm": "Sleeve length from shoulder seam to cuff.",
      "length_cm": "Garment length from highest point of shoulder to hem.",
      "rise_cm": "Rise length (for bottoms) from crotch to waistband top.",
      "hip_cm": "Full garment hip circumference (flat × 2).",
      "inseam_cm": "Inner leg seam from crotch to hem.",
      "outseam_cm": "Outer leg seam from waistband to hem."
    },
    "size_mapping": {
      "_note": "Snag Tights letter codes map to standard sizes via size_charts.normalize_size_label()",
      "A / A1 / A2": "XS",
      "B / B1 / B2": "S",
      "C / C1 / C2": "M",
      "D / D1 / D2": "L",
      "E / E1 / E2": "XL",
      "F / F1 / F2": "2XL",
      "G / G1 / G2": "3XL",
      "H / H1 / H2": "4XL"
    }
  },

