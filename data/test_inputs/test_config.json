{
  "description": "FitFusion primary test — size M model wearing XL Cropped Borg Aviator Jacket. Validates the LOOSE-fit code path of the size-aware system.",

  "person_image": "data/test_inputs/person_model_C_Pixie.jpg",
  "garment_image": "data/test_inputs/garment_cropped_borg_aviator_jacket_black.png",

  "person": {
    "model_id": "snag_tights_model_C",
    "label": "Snag Tights Size C (Pixie)",
    "size_label": "M",
    "snag_label": "C",
    "uk_size": "10–12",
    "bust_cm": 92,
    "waist_cm": 76,
    "hips_cm": 100,
    "height_cm": 167
  },

  "garment": {
    "garment_id": "cropped-borg-aviator-jacket-black",
    "brand": "snag_tights",
    "name": "Cropped Borg Aviator Jacket — Black",
    "garment_type": "top",
    "fit_style": "relaxed",
    "size_key": "E1",
    "size_label": "XL",
    "uk_size": "14–18",
    "measurements": {
      "chest_cm": 120,
      "shoulder_cm": 46,
      "sleeve_cm": 62,
      "length_cm": 54,
      "hem_cm": 116
    }
  },

  "size_physics": {
    "person_size": "M",
    "garment_size": "XL",
    "snag_garment_size": "E1",
    "width_ratio": 1.20,
    "length_ratio": 1.04,
    "size_gap": 2,
    "expected_fit_type": "LOOSE",
    "bust_difference_cm": 28,
    "waist_difference_cm": 36,
    "_note": "garment chest (120cm) vs person bust (92cm) = +28cm = correct LOOSE fit for an oversized jacket"
  },

  "inference_params": {
    "person_size": "M",
    "target_size": "XL",
    "garment_type": "top",
    "steps": 30,
    "guidance_scale": 2.0,
    "seed": 42,
    "width": 768,
    "height": 1024
  },

  "run_command": "python run_pipeline.py --person_image data/test_inputs/person_model_C_Pixie.jpg --garment_image data/test_inputs/garment_cropped_borg_aviator_jacket_black.png --person_size M --target_size XL --garment_type top --ckpt_dir ./ckpt --output_dir ./output --steps 30 --guidance_scale 2.0 --seed 42 --device cuda --skip_preprocessing",

  "additional_test_scenarios": [
    {
      "description": "Same model, 3XL jacket — very loose",
      "target_size": "3XL",
      "garment_size_key": "G2",
      "garment_measurements": {"chest_cm": 134, "shoulder_cm": 50, "sleeve_cm": 64, "length_cm": 56},
      "expected_width_ratio": 1.34,
      "expected_fit": "VERY_LOOSE"
    },
    {
      "description": "Same model, L jacket — slightly loose",
      "target_size": "L",
      "garment_size_key": "D1",
      "garment_measurements": {"chest_cm": 108, "shoulder_cm": 44, "sleeve_cm": 60, "length_cm": 52},
      "expected_width_ratio": 1.08,
      "expected_fit": "SLIGHTLY_LOOSE"
    },
    {
      "description": "Same model, 4XL jacket — extreme oversize",
      "target_size": "4XL",
      "garment_size_key": "H2",
      "garment_measurements": {"chest_cm": 144, "shoulder_cm": 52, "sleeve_cm": 66, "length_cm": 58},
      "expected_width_ratio": 1.44,
      "expected_fit": "VERY_LOOSE"
    }
  ]
}

